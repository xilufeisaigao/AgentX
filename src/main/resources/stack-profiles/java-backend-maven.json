          ],
          "description": "Readonly recursive grep inside the workspace."
        },
        {
          "commandId": "read-range",
          "argvTemplate": [
            "sed",
            "-n",
            "${startLine},${endLine}p",
            "${path}"
          ],
          "allowedArgs": [
            "startLine",
            "endLine",
            "path"
          ],
          "description": "Readonly line-range read for a file."
        }
      ],
      "postDeliveryCommandIds": [],
      "verifyCommandIds": [],
      "httpEndpoints": [
        {
          "endpointId": "local-http",
          "baseUrl": "http://127.0.0.1",
          "allowedMethods": [
            "GET",
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ],
          "description": "Deterministic local endpoint baseline for API smoke and verification."
        }
      ],
      "cleanupPaths": [],
      "reportHints": [
        "api-smoke"
      ]
    },
    {
      "capabilityPackId": "cap-verify",
      "runtimeImage": "maven:3.9.11-eclipse-temurin-21",
      "environment": {
        "AGENTX_PROFILE_ID": "java-backend-maven"
      },
