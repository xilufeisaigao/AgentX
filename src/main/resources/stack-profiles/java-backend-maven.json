      ]
    }
  ],
  "eval": {
    "roleGlobs": {
      "source": [
        "src/main/java/**"
      ],
      "test": [
        "src/test/java/**"
      ],
      "config": [
        "pom.xml",
        "src/main/resources/**",
        "db/schema/**"
      ],
      "docs": [
        "docs/**",
        "progress.md",
        "README.md"
      ]
    },
    "requiredArtifactRoles": [
      "source",
      "test"
    ],
    "buildCommandIds": [
      "maven-test"
    ],
    "apiCommandIds": [],
    "integrationCommandIds": [],
    "frontendConnectivityChecks": []
  },
  "reporting": {
    "labels": [
      "java",
      "backend",
      "maven"
    ],
    "highlightedRoles": [
      "source",
      "test"
    ],
    "enabledDimensions": [
      "NODE_CONTRACT",
      "WORKFLOW_TRAJECTORY",
      "DAG_QUALITY",
