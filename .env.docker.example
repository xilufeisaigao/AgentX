AGENTX_BACKEND_PORT=18082
AGENTX_MYSQL_PORT=13306
AGENTX_REDIS_PORT=16379
AGENTX_GIT_EXPORT_PORT=19418

AGENTX_DB_NAME=agentx_backend
AGENTX_DB_USERNAME=agentx
AGENTX_DB_PASSWORD=
MYSQL_ROOT_PASSWORD=
AGENTX_DB_TIMEZONE=Asia/Shanghai

AGENTX_REDIS_PASSWORD=

# Host path for generated source code and git worktrees.
# Relative path is resolved from repository root.
AGENTX_HOST_REPO_ROOT=./runtime-projects/default-repo

# LLM runtime defaults.
AGENTX_LLM_OUTPUT_LANGUAGE=zh-CN
AGENTX_RUNTIME_LLM_CONFIG_FILE_PATH=/agentx/runtime-data/runtime/runtime-llm-config.json
AGENTX_REQUIREMENT_LLM_PROVIDER=mock
AGENTX_REQUIREMENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENTX_REQUIREMENT_LLM_MODEL=qwen3.5-plus-2026-02-15
AGENTX_REQUIREMENT_LLM_API_KEY=
AGENTX_WORKER_RUNTIME_LLM_PROVIDER=mock
AGENTX_WORKER_RUNTIME_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENTX_WORKER_RUNTIME_LLM_MODEL=qwen3.5-plus-2026-02-15
AGENTX_WORKER_RUNTIME_LLM_API_KEY=

AGENTX_MERGEGATE_GIT_MAIN_BRANCH=main
AGENTX_EXECUTION_VERIFY_WORKER_ID=WRK-BOOT-JAVA-CORE
AGENTX_WORKER_RUNTIME_ENABLED=true
AGENTX_WORKFORCE_BOOTSTRAP_DEFAULT_WORKERS=true
AGENTX_DELIVERY_CLONE_PUBLISH_PUBLIC_BASE=git://127.0.0.1:19418
AGENTX_DELIVERY_CLONE_PUBLISH_RETENTION_HOURS=72

# Optional worker pool cleanup tuning
AGENTX_WORKFORCE_WORKER_POOL_CLEANUP_MAX_WORKERS_TOTAL=32
AGENTX_WORKFORCE_WORKER_POOL_CLEANUP_MIN_IDLE_SECONDS=1800
AGENTX_WORKFORCE_WORKER_POOL_CLEANUP_MAX_DISABLE_PER_POLL=2
AGENTX_WORKFORCE_WORKER_POOL_CLEANUP_STRATEGY=oldest_idle

# Optional runtime database virtual account provisioning
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_ENABLED=true
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_USERNAME_PREFIX=ax
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_PASSWORD_LENGTH=20
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_PROVIDERS=mysql,postgresql,redis,mongodb,sqlserver,oracle
# JSON object, example:
# {"postgresql":"psql -h ${host} -p ${port} -U ${admin_username} -d postgres -c \"create user ${username} with password '${password}';\""}
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_COMMAND_TEMPLATES_JSON={}
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_POSTGRESQL_HOST=127.0.0.1
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_POSTGRESQL_PORT=5432
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_POSTGRESQL_DATABASE=agentx_backend
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_POSTGRESQL_ADMIN_DATABASE=postgres
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_POSTGRESQL_ADMIN_USERNAME=postgres
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_POSTGRESQL_ADMIN_PASSWORD=
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_REDIS_HOST=127.0.0.1
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_REDIS_PORT=6379
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_REDIS_DATABASE=0
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_REDIS_ADMIN_USERNAME=
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_REDIS_ADMIN_PASSWORD=
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_MONGODB_HOST=127.0.0.1
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_MONGODB_PORT=27017
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_MONGODB_DATABASE=agentx_backend
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_MONGODB_ADMIN_DATABASE=admin
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_MONGODB_ADMIN_USERNAME=root
AGENTX_WORKFORCE_RUNTIME_ENVIRONMENT_DB_ACCOUNT_MONGODB_ADMIN_PASSWORD=
